APP_NAME=Telegram Notification API
ENVIRONMENT=development
DEBUG=true

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/telegram_notifier

# REDIS_URL=redis://localhost:6379/0    # Optional — falls back to in-memory rate limiter

SECRET_KEY=change-this-to-a-long-random-string
ENCRYPTION_KEY=change-this-to-a-32-byte-base64-key=

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=["*"]

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

DEFAULT_MESSAGE_RATE_PER_MINUTE=5
DEFAULT_MESSAGE_RATE_PER_DAY=100
DEFAULT_MAX_BOTS=1
